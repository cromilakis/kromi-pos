# Plantilla para el bootstrap de producción (scripts/bootstrap-prod.mjs).
# Copiar a .env.local (git lo ignora) y completar. NO commitear .env.local.
#
#   node --env-file=.env.local scripts/bootstrap-prod.mjs

# --- Secretos ---------------------------------------------------------------
# Secret key nueva (Dashboard → Settings → API Keys → Secret keys). Empieza con sb_secret_.
# Reemplaza a la legacy service_role; bypassa RLS. NO usar la publishable aquí.
SUPABASE_SECRET_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxxx
# PIN de 6 dígitos con el que el admin inicia sesión.
ADMIN_PIN=000000

# --- Opcional ---------------------------------------------------------------
# Por defecto apunta al proyecto kromi-pos cloud.
# SUPABASE_URL=https://immuembrvocwbdpprypk.supabase.co

# --- Datos del negocio / sucursal / admin -----------------------------------
BOOTSTRAP_BUSINESS_NAME=Mi Negocio SpA
BOOTSTRAP_BUSINESS_RUT=76.123.456-7
BOOTSTRAP_BUSINESS_GIRO=Venta al por menor
BOOTSTRAP_BUSINESS_DIRECCION=Calle 123, Ciudad
BOOTSTRAP_BUSINESS_PLAN=Básico
BOOTSTRAP_BRANCH_NAME=Casa Matriz
BOOTSTRAP_BRANCH_ADDRESS=Calle 123, Ciudad
BOOTSTRAP_REGISTER_NAME=Caja 1
BOOTSTRAP_ADMIN_NAME=Nombre Apellido
BOOTSTRAP_ADMIN_RUT=11.111.111-1
